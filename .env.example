# AICA_GITHUB_INSTALLATION_TOKEN (short-lived workflow token), never both.
# AICA_GITHUB_APP_ID=123456
# AICA_GITHUB_APP_INSTALLATION_ID=78901234
# AICA_GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----...
AICA_GITHUB_INSTALLATION_TOKEN=
