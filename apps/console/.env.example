# Use "mock" for the sanitized baseline/retest fixtures or "api" for live read/command interfaces.
VITE_DATA_SOURCE=mock
VITE_API_BASE_URL=/api/v1

# Produces the public, sanitized, read-only build when true.
VITE_PUBLIC_MODE=false

# Required only when the API does not expose an evaluation ID through the run record yet.
VITE_EVALUATION_ID=AIEVAL-RETEST-001

# Local FastAPI convenience only. Production identity is injected by Container Apps Easy Auth.
VITE_DEV_REVIEWER_ID=local-reviewer
VITE_DEV_ROLES=Assurance.Assessor,Assurance.Reviewer,Assurance.RiskApprover
