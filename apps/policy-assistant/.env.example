VITE_DATA_SOURCE=mock
VITE_API_BASE_URL=/api/v1

# Locks the UI to deterministic replay while preserving the explicit-confirmation demo.
VITE_REPLAY_ONLY=false

# Local FastAPI convenience only. Production identity is injected by Container Apps Easy Auth.
VITE_DEV_REVIEWER_ID=local-policy-user
VITE_DEV_ROLES=Assurance.Assessor
