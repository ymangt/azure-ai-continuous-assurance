        "collector_version": {
          "minLength": 1,
          "title": "Collector Version",
          "type": "string"
        },
        "freshness": {
          "$ref": "#/$defs/EvidenceFreshness"
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "observation_window_end": {
          "format": "date-time",
          "title": "Observation Window End",
          "type": "string"
        },
        "observation_window_start": {
          "format": "date-time",
          "title": "Observation Window Start",
          "type": "string"
        },
        "payload": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "items": {},
              "type": "array"
            },
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Payload"
        },
        "private_artifact_uri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "format": "uri",
              "maxLength": 2083,
              "minLength": 1,
              "type": "string"
            }
          ],
          "title": "Private Artifact Uri"
        },
        "query_digest": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Query Digest",
          "type": "string"
        },
        "redaction_profile": {
          "minLength": 1,
          "title": "Redaction Profile",
          "type": "string"
        },
        "sanitized_sha256": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sanitized Sha256"
        },
        "scope": {
          "items": {
            "type": "string"
          },
          "title": "Scope",
          "type": "array"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "source": {
          "minLength": 1,
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "id",
        "source",
        "scope",
        "captured_at",
        "observation_window_start",
        "observation_window_end",
        "query_digest",
        "collector_version",
        "private_artifact_uri",
        "media_type",
        "sha256",
        "classification",
        "freshness",
        "redaction_profile"
      ],
