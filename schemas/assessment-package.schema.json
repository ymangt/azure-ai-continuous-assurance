{
  "$defs": {
    "AssessmentMethod": {
      "enum": [
        "EXAMINE",
        "INTERVIEW",
        "TEST",
        "HYBRID"
      ],
      "title": "AssessmentMethod",
      "type": "string"
    },
    "AssessmentRun": {
      "additionalProperties": false,
      "properties": {
        "collector_version": {
          "minLength": 1,
          "title": "Collector Version",
          "type": "string"
        },
        "ended_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ended At"
        },
        "estimated_cost_cad": {
          "default": 0,
          "minimum": 0,
          "title": "Estimated Cost Cad",
          "type": "number"
        },
        "evaluator_version": {
          "minLength": 1,
          "title": "Evaluator Version",
          "type": "string"
        },
        "git_commit": {
          "pattern": "^[a-fA-F0-9]{7,40}$",
          "title": "Git Commit",
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "manifest_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Manifest Digest"
        },
        "observation_window_end": {
          "format": "date-time",
          "title": "Observation Window End",
          "type": "string"
        },
        "observation_window_start": {
          "format": "date-time",
          "title": "Observation Window Start",
          "type": "string"
        },
        "prior_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prior Run Id"
        },
        "scope": {
          "items": {
            "type": "string"
          },
          "title": "Scope",
          "type": "array"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/RunStatus"
        },
        "trigger": {
          "enum": [
            "manual",
            "scheduled",
            "change",
            "retest",
            "fixture"
          ],
          "title": "Trigger",
          "type": "string"
        }
      },
      "required": [
        "id",
        "trigger",
        "scope",
        "observation_window_start",
        "observation_window_end",
        "git_commit",
        "collector_version",
        "evaluator_version",
        "started_at",
        "status"
      ],
      "title": "AssessmentRun",
      "type": "object"
    },
    "Classification": {
      "enum": [
        "PUBLIC",
        "INTERNAL",
        "CONFIDENTIAL",
        "RESTRICTED_TEST_EVIDENCE"
      ],
      "title": "Classification",
      "type": "string"
    },
    "ControlAssessment": {
      "additionalProperties": false,
      "properties": {
        "conclusion": {
          "$ref": "#/$defs/Effectiveness"
        },
        "coverage_percent": {
          "maximum": 100,
          "minimum": 0,
          "title": "Coverage Percent",
          "type": "number"
        },
        "design_effectiveness": {
          "$ref": "#/$defs/Effectiveness"
        },
        "evidence_freshness": {
          "$ref": "#/$defs/EvidenceFreshness"
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "objective_id": {
          "minLength": 1,
          "title": "Objective Id",
          "type": "string"
        },
        "operating_effectiveness": {
          "$ref": "#/$defs/Effectiveness"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "review_state": {
          "$ref": "#/$defs/ReviewState",
          "default": "SUGGESTED"
        },
        "reviewer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reviewer"
        },
        "run_id": {
          "minLength": 1,
          "title": "Run Id",
          "type": "string"
        }
      },
      "required": [
        "id",
        "run_id",
        "objective_id",
        "design_effectiveness",
        "operating_effectiveness",
        "coverage_percent",
        "conclusion",
        "rationale",
        "evidence_freshness"
      ],
      "title": "ControlAssessment",
      "type": "object"
    },
    "ControlObjective": {
      "additionalProperties": false,
      "properties": {
        "automated": {
          "title": "Automated",
          "type": "boolean"
        },
        "cadence": {
          "minLength": 1,
          "title": "Cadence",
          "type": "string"
        },
        "crosswalk": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Crosswalk",
          "type": "object"
        },
        "evidence_requirements": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Requirements",
          "type": "array"
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "methods": {
          "items": {
            "$ref": "#/$defs/AssessmentMethod"
          },
          "title": "Methods",
          "type": "array"
        },
        "objective": {
          "minLength": 1,
          "title": "Objective",
          "type": "string"
        },
        "owner": {
          "minLength": 1,
          "title": "Owner",
          "type": "string"
        },
        "source_control": {
          "minLength": 1,
          "title": "Source Control",
          "type": "string"
        },
        "subject_selector": {
          "minLength": 1,
          "title": "Subject Selector",
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "id",
        "source_control",
        "title",
        "objective",
        "methods",
        "subject_selector",
        "cadence",
        "evidence_requirements",
        "owner",
        "automated"
      ],
      "title": "ControlObjective",
      "type": "object"
    },
    "Effectiveness": {
      "enum": [
        "EFFECTIVE",
        "PARTIALLY_EFFECTIVE",
        "INEFFECTIVE",
        "NOT_CONCLUDED"
      ],
      "title": "Effectiveness",
      "type": "string"
    },
    "EvidenceFreshness": {
      "enum": [
        "FRESH",
        "STALE",
        "UNKNOWN"
      ],
      "title": "EvidenceFreshness",
      "type": "string"
    },
    "EvidenceItem": {
      "additionalProperties": false,
