{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://example.invalid/aica/schemas/core-contracts.schema.json",
  "title":"AICA Core Assurance Contracts",
  "description":"Shared record definitions. Semantic invariants such as stale-required-evidence => NOT_CONCLUDED and score=likelihood*impact are enforced by application tests in addition to schema validation.",
  "$defs":{
    "sha256":{"type":"string","pattern":"^(sha256:)?[a-f0-9]{64}$"},
    "timestamp":{"type":"string","format":"date-time"},
    "reference":{"type":"string","minLength":1,"maxLength":200},
    "observationWindow":{"type":"object","required":["start","end"],"additionalProperties":false,"properties":{"start":{"$ref":"#/$defs/timestamp"},"end":{"$ref":"#/$defs/timestamp"}}},
    "assessmentRun":{"type":"object","required":["run_id","trigger","scope","observation_window","git_commit","collector_version","evaluator_version","started_at","ended_at","status","manifest_digest"],"properties":{"run_id":{"type":"string","format":"uuid"},"display_id":{"type":"string"},"trigger":{"enum":["SCHEDULED","CHANGE","MANUAL","RETEST","SCENARIO_CAMPAIGN"]},"scope":{"type":"object"},"observation_window":{"$ref":"#/$defs/observationWindow"},"git_commit":{"type":"string","pattern":"^[a-f0-9]{40}$"},"collector_version":{"type":"string"},"evaluator_version":{"type":"string"},"started_at":{"$ref":"#/$defs/timestamp"},"ended_at":{"$ref":"#/$defs/timestamp"},"status":{"enum":["QUEUED","COLLECTING","EVALUATING","REVIEW_REQUIRED","COMPLETED","FAILED"]},"manifest_digest":{"oneOf":[{"$ref":"#/$defs/sha256"},{"type":"null"}],"description":"Null until the final signed manifest is emitted; avoids a self-referential digest."}}},
    "controlObjective":{"type":"object","required":["id","control_id","objective","method","subject_selector","cadence","evidence_requirements","owner","limitations"],"additionalProperties":false,"properties":{"id":{"type":"string","pattern":"^[A-Z0-9-]+\\.[0-9]+$"},"control_id":{"type":"string","pattern":"^[A-Z0-9-]+$"},"objective":{"type":"string","minLength":20},"method":{"enum":["AUTOMATED","HYBRID","MANUAL"]},"subject_selector":{"type":"string"},"cadence":{"type":"string"},"evidence_requirements":{"type":"array","minItems":1,"items":{"type":"string"}},"owner":{"type":"string"},"limitations":{"type":"string","minLength":10}}},
    "evidenceItem":{"type":"object","required":["evidence_id","source","scope","captured_at","capture_window","api_query_digest","collector_version","private_artifact_uri","media_type","sha256","blob_version_id","classification","freshness","redaction","sanitized_summary"],"properties":{"evidence_id":{"$ref":"#/$defs/reference"},"source":{"type":"string"},"scope":{"type":"string"},"captured_at":{"$ref":"#/$defs/timestamp"},"capture_window":{"$ref":"#/$defs/observationWindow"},"api_query_digest":{"$ref":"#/$defs/sha256"},"collector_version":{"type":"string"},"private_artifact_uri":{"oneOf":[{"type":"string","pattern":"^az://private-evidence/"},{"const":"private://withheld"}]},"media_type":{"type":"string"},"sha256":{"$ref":"#/$defs/sha256"},"blob_version_id":{"type":"string"},"classification":{"enum":["PUBLIC","INTERNAL","RESTRICTED_ASSURANCE","CONTROLLED_EVALUATION"]},"freshness":{"type":"object","required":["state","max_age_seconds","age_seconds_at_evaluation"],"properties":{"state":{"enum":["FRESH","STALE","UNKNOWN"]},"max_age_seconds":{"type":"integer","minimum":1},"age_seconds_at_evaluation":{"type":["integer","null"],"minimum":0}}},"redaction":{"type":"object","required":["profile","status","fields"],"properties":{"profile":{"type":"string"},"status":{"enum":["APPLIED","NOT_REQUIRED","FAILED"]},"fields":{"type":"array","items":{"type":"string"}}}},"collection_error":{"type":"object","required":["code","message"],"properties":{"code":{"type":"string"},"http_status":{"type":["integer","null"]},"retryable":{"type":"boolean"},"message":{"type":"string"}}},"sanitized_summary":{"type":"string"}}},
    "testResult":{"type":"object","required":["result_id","objective_id","status","reason","test_version","evidence_refs"],"properties":{"result_id":{"$ref":"#/$defs/reference"},"objective_id":{"$ref":"#/$defs/reference"},"status":{"enum":["PASS","FAIL","ERROR","NOT_RUN","NOT_APPLICABLE"]},"reason":{"type":"string","minLength":10},"test_version":{"type":"string"},"evidence_refs":{"type":"array","items":{"$ref":"#/$defs/reference"}},"finding_refs":{"type":"array","items":{"$ref":"#/$defs/reference"}},"retest_ref":{"$ref":"#/$defs/reference"}}},
    "controlAssessment":{"type":"object","required":["control_id","design_effectiveness","operating_effectiveness","coverage","assessor_conclusion","reviewer","rationale"],"properties":{"control_id":{"$ref":"#/$defs/reference"},"design_effectiveness":{"enum":["EFFECTIVE","PARTIALLY_EFFECTIVE","INEFFECTIVE","NOT_CONCLUDED","NOT_APPLICABLE"]},"operating_effectiveness":{"enum":["EFFECTIVE","PARTIALLY_EFFECTIVE","INEFFECTIVE","NOT_CONCLUDED","NOT_APPLICABLE"]},"coverage":{"type":"object","required":["objectives_assessed","objectives_total","evidence_complete"],"properties":{"objectives_assessed":{"type":"integer","minimum":0},"objectives_total":{"type":"integer","minimum":1},"evidence_complete":{"type":"boolean"}}},"assessor_conclusion":{"enum":["EFFECTIVE","EFFECTIVE_WITH_LIMITATION","EFFECTIVE_WITH_EXCEPTION","PARTIALLY_EFFECTIVE","INEFFECTIVE","NOT_CONCLUDED","NOT_APPLICABLE"]},"reviewer":{"type":"string"},"rationale":{"type":"string","minLength":10}}},
    "observation":{"type":"object","required":["observation_id","statement","observed_at","subject_refs","evidence_refs"],"properties":{"observation_id":{"$ref":"#/$defs/reference"},"statement":{"type":"string","minLength":10},"observed_at":{"$ref":"#/$defs/timestamp"},"subject_refs":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/reference"}},"evidence_refs":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/reference"}}}},
    "finding":{"type":"object","required":["finding_id","criteria","condition","cause","consequence","affected_controls","affected_objectives","affected_assets","severity","severity_rationale","observation_refs","test_result_refs","evidence_refs","risk_refs","status"],"properties":{"finding_id":{"$ref":"#/$defs/reference"},"criteria":{"type":"string"},"condition":{"type":"string"},"cause":{"type":"string"},"consequence":{"type":"string"},"affected_controls":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/reference"}},"affected_objectives":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/reference"}},"affected_assets":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/reference"}},"severity":{"enum":["LOW","MODERATE","HIGH","CRITICAL"]},"severity_rationale":{"type":"string"},"observation_refs":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/reference"}},"test_result_refs":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/reference"}},"evidence_refs":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/reference"}},"risk_refs":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/reference"}},"status":{"enum":["OPEN","READY_FOR_RETEST","CLOSED","REOPENED"]},"closed_by_retest":{"$ref":"#/$defs/reference"}}},
    "risk":{"type":"object","required":["risk_id","statement","likelihood","impact","inherent_score","inherent_rating","residual_score","residual_rating","confidence","treatment","owner","finding_refs","review_date"],"properties":{"risk_id":{"$ref":"#/$defs/reference"},"statement":{"type":"string","minLength":20},"likelihood":{"type":"integer","minimum":1,"maximum":5},"impact":{"type":"integer","minimum":1,"maximum":5},"inherent_score":{"type":"integer","minimum":1,"maximum":25},"inherent_rating":{"enum":["LOW","MODERATE","HIGH","CRITICAL"]},"residual_score":{"type":"integer","minimum":1,"maximum":25},"residual_rating":{"enum":["LOW","MODERATE","HIGH","CRITICAL"]},"confidence":{"enum":["LOW","MODERATE","HIGH"]},"treatment":{"enum":["MITIGATE","AVOID","TRANSFER","ACCEPT_WITH_EXCEPTION","CLOSED_AFTER_MITIGATION"]},"owner":{"type":"string"},"finding_refs":{"type":"array","items":{"$ref":"#/$defs/reference"}},"exception_ref":{"$ref":"#/$defs/reference"},"review_date":{"type":"string","format":"date"}}},
    "exception":{"type":"object","required":["exception_id","subject_ref","approver","rationale","compensating_controls","approved_at","expires_at","review_cadence","status"],"properties":{"exception_id":{"$ref":"#/$defs/reference"},"subject_ref":{"$ref":"#/$defs/reference"},"approver":{"type":"string"},"rationale":{"type":"string"},"compensating_controls":{"type":"array","minItems":1,"items":{"type":"string"}},"approved_at":{"$ref":"#/$defs/timestamp"},"expires_at":{"$ref":"#/$defs/timestamp"},"review_cadence":{"type":"string"},"status":{"enum":["PROPOSED","APPROVED","EXPIRED","REVOKED"]}}},
    "remediation":{"type":"object","required":["remediation_id","finding_ref","owner","action","target_date","status","pull_request_ref","evidence_refs"],"properties":{"remediation_id":{"$ref":"#/$defs/reference"},"finding_ref":{"$ref":"#/$defs/reference"},"owner":{"type":"string"},"action":{"type":"string"},"target_date":{"type":"string","format":"date"},"status":{"enum":["PLANNED","IN_PROGRESS","READY_FOR_RETEST","COMPLETED","CANCELLED"]},"commit_ref":{"type":["string","null"]},"pull_request_ref":{"type":["string","null"]},"evidence_refs":{"type":"array","items":{"$ref":"#/$defs/reference"}}}},
    "retest":{"type":"object","required":["retest_id","before_run_id","after_run_id","prior_result_ref","new_result_ref","new_evidence_refs","result","decision","rationale"],"properties":{"retest_id":{"$ref":"#/$defs/reference"},"finding_ref":{"type":["string","null"]},"before_run_id":{"type":"string","format":"uuid"},"after_run_id":{"type":"string","format":"uuid"},"prior_result_ref":{"$ref":"#/$defs/reference"},"new_result_ref":{"$ref":"#/$defs/reference"},"new_evidence_refs":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/reference"}},"result":{"enum":["PASS","FAIL","ERROR"]},"decision":{"enum":["CLOSE","REOPEN","REMAIN_OPEN","CONCLUDE"]},"rationale":{"type":"string"}}},
    "reviewDecision":{"type":"object","required":["decision_id","reviewer","subject_ref","prior_state","decision","rationale","timestamp","artifact_hash"],"properties":{"decision_id":{"$ref":"#/$defs/reference"},"reviewer":{"type":"string"},"subject_ref":{"$ref":"#/$defs/reference"},"prior_state":{"type":"string"},"decision":{"type":"string"},"rationale":{"type":"string","minLength":10},"timestamp":{"$ref":"#/$defs/timestamp"},"artifact_hash":{"$ref":"#/$defs/sha256"}}}
  }
}
