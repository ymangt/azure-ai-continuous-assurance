  "$id": "https://example.invalid/aica/schemas/system-record.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Versioned, runtime system-boundary record included in every package.",
  "properties": {
    "boundary": {
      "minLength": 1,
      "title": "Boundary",
      "type": "string"
    },
    "classifications": {
      "items": {
        "$ref": "#/$defs/SystemClassification"
      },
      "minItems": 1,
      "title": "Classifications",
      "type": "array"
    },
    "data_classification": {
      "minLength": 1,
      "title": "Data Classification",
      "type": "string"
    },
    "data_flows": {
      "items": {
        "$ref": "#/$defs/SystemDataFlow"
      },
      "minItems": 1,
      "title": "Data Flows",
      "type": "array"
    },
    "exclusions": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Exclusions",
      "type": "array"
    },
    "identities": {
      "items": {
        "$ref": "#/$defs/SystemIdentity"
      },
      "minItems": 1,
      "title": "Identities",
      "type": "array"
    },
    "inventory": {
      "items": {
        "$ref": "#/$defs/SystemInventoryItem"
      },
      "minItems": 1,
      "title": "Inventory",
      "type": "array"
    },
    "name": {
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "shared_responsibility": {
      "minLength": 1,
      "title": "Shared Responsibility",
      "type": "string"
    },
    "system_id": {
      "minLength": 1,
      "title": "System Id",
      "type": "string"
    },
    "trust_boundaries": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Trust Boundaries",
      "type": "array"
    }
  },
  "required": [
    "system_id",
    "name",
    "boundary",
    "data_classification",
    "data_flows",
    "trust_boundaries",
    "inventory",
    "identities",
    "classifications",
    "shared_responsibility",
    "exclusions"
