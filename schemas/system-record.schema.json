      "title": "Classification",
      "type": "string"
    },
    "SystemClassification": {
      "additionalProperties": false,
      "properties": {
        "classification": {
          "$ref": "#/$defs/Classification"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "handling": {
          "minLength": 1,
          "title": "Handling",
          "type": "string"
        }
      },
      "required": [
        "classification",
        "description",
        "handling"
      ],
      "title": "SystemClassification",
      "type": "object"
    },
    "SystemDataFlow": {
      "additionalProperties": false,
      "properties": {
        "classification": {
          "$ref": "#/$defs/Classification"
        },
        "data": {
          "minLength": 1,
          "title": "Data",
          "type": "string"
        },
        "destination": {
          "minLength": 1,
          "title": "Destination",
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "protection": {
          "minLength": 1,
          "title": "Protection",
          "type": "string"
        },
        "retention": {
          "minLength": 1,
          "title": "Retention",
          "type": "string"
        },
        "source": {
          "minLength": 1,
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "id",
        "source",
        "destination",
        "data",
        "classification",
        "protection",
        "retention"
      ],
      "title": "SystemDataFlow",
      "type": "object"
    },
    "SystemIdentity": {
      "additionalProperties": false,
      "properties": {
        "assigned_scope": {
          "minLength": 1,
          "title": "Assigned Scope",
          "type": "string"
        },
        "authentication": {
          "minLength": 1,
          "title": "Authentication",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "privilege": {
          "minLength": 1,
          "title": "Privilege",
          "type": "string"
        },
        "purpose": {
          "minLength": 1,
          "title": "Purpose",
          "type": "string"
        }
