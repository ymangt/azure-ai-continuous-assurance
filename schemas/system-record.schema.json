          "minLength": 1,
          "title": "Lifecycle",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "plane": {
          "minLength": 1,
          "title": "Plane",
          "type": "string"
        },
        "region": {
          "minLength": 1,
          "title": "Region",
          "type": "string"
        },
        "type": {
          "minLength": 1,
          "title": "Type",
          "type": "string"
        }
